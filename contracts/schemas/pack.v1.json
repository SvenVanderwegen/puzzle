{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burnfront.com/schemas/pack.v1.json",
  "title": "burnfront.pack/1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "title",
    "puzzles"
  ],
  "properties": {
    "schema": {
      "const": "burnfront.pack/1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "puzzles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "file",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "$comment": "Path relative to the manifest."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "technique": {
            "type": "string",
            "$comment": "Academy packs: the deduction argument this board is filtered to require (WS-05/12)."
          }
        }
      }
    }
  }
}