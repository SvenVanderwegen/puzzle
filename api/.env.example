# Burnfront API — example environment (fake values only; real secrets live in Forge).

APP_NAME=Burnfront
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# SPA origin; magic-link emails point here (ADR-0003).
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=burnfront
DB_USERNAME=burnfront
DB_PASSWORD=fake-local-password

# Sanctum stateful SPA sessions (ADR-0003). Sessions live in Redis in production.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=burnfront_session
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,localhost:5173,127.0.0.1,127.0.0.1:8000,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Horizon drives Redis queues (rating jobs, GDPR jobs). Tests use the sync queue.
QUEUE_CONNECTION=redis

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Content delivery (WS-07). The fallback flag embeds boards in GET /daily/{date}
# during CDN outages; the public key verifies content manifest signatures
# (fake dev path — the real key lives in Forge).
CONTENT_CDN_URL_TEMPLATE="https://content.burnfront.com/puzzles/{id}.json"
CONTENT_ORIGIN_FALLBACK=false
CONTENT_SIGNING_PUBLIC_KEY_PATH=storage/app/private/content-signing-dev.pub

# Local mail goes to mailpit. Production sends through the EU ESP's SMTP relay
# (WS-21) — the code is deliberately ESP-agnostic; vendor choice, DPA and the
# SPF/DKIM/DMARC DNS records are owner actions listed in tasks/WS-21/STATUS.md.
# Real credentials live in Forge only. Production shape:
#   MAIL_HOST=<esp smtp endpoint>   MAIL_PORT=587        MAIL_SCHEME=smtp
#   MAIL_USERNAME=<esp user>        MAIL_PASSWORD=<esp key>
#   MAIL_FROM_ADDRESS="dispatch@burnfront.com"  MAIL_EHLO_DOMAIN=burnfront.com
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="dispatch@burnfront.test"
MAIL_FROM_NAME="${APP_NAME}"

# Monitoring (WS-18, ADR-0010). Nightwatch is installed and config-ready;
# local and CI run disabled. Staging/production set NIGHTWATCH_ENABLED=true
# plus the real NIGHTWATCH_TOKEN in Forge (owner blocker in
# tasks/WS-18/STATUS.md) and run the nightwatch:agent daemon — per-site
# values and alert definitions live in docs/RUNBOOK.md section 6.
NIGHTWATCH_ENABLED=false
NIGHTWATCH_TOKEN=
# Staging runs its own agent on its own port (production keeps the default):
# NIGHTWATCH_INGEST_URI=127.0.0.1:2408

# Ops alert sink (ops:content-freshness / ops:content-runway, WS-18). A real
# notifier later is one env change, e.g. OPS_LOG_CHANNELS=stack,slack.
OPS_LOG_CHANNELS=stack

# Weekly first-party analytics digest recipient (WS-19, ADR-0008).
# Fake value — the real owner address lives in Forge.
OWNER_DIGEST_EMAIL=owner@burnfront.test

# Landing social-proof counter (WS-19): live daily solve count at >=500
# solves, rank fallback below that (product.md §2.5).
LANDING_LIVE_COUNTER=true
